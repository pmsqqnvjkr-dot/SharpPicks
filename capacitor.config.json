{
  "appId": "ai.sharppicks.app",
  "appName": "SharpPicks",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "url": "https://app.sharppicks.ai",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#111827",
      "showSpinner": false,
      "launchShowDuration": 2000
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#111827"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "backgroundColor": "#111827"
  }
}
