{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "uv": "0.11.8",
    "python": "3.13",
    "node": "22"
  },
  "buildAptPackages": [
    "libglib2.0-0", "libnss3", "libnspr4", "libatk1.0-0",
    "libatk-bridge2.0-0", "libcups2", "libdrm2", "libxkbcommon0",
    "libxcomposite1", "libxdamage1", "libxfixes3", "libxrandr2",
    "libgbm1", "libpango-1.0-0", "libcairo2", "libasound2",
    "libatspi2.0-0", "libdbus-1-3", "libx11-6", "libx11-xcb1",
    "libxcb1", "libxext6", "libxshmfence1", "fonts-liberation"
  ],
  "caches": {
    "uv":         { "directory": "/root/.cache/uv",            "type": "shared" },
    "npm":        { "directory": "/root/.npm",                 "type": "shared" },
    "playwright": { "directory": "/root/.cache/ms-playwright", "type": "shared" }
  },
  "steps": {
    "install": {
      "caches": ["uv", "npm", "playwright"],
      "commands": [
        "uv sync --no-dev --no-install-project",
        "npm ci || npm install",
        "(cd emails && npm install)",
        "uv run playwright install chromium"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "uv sync --no-dev --no-editable",
        "npm run build"
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "libglib2.0-0", "libnss3", "libnspr4", "libatk1.0-0",
      "libatk-bridge2.0-0", "libcups2", "libdrm2", "libxkbcommon0",
      "libxcomposite1", "libxdamage1", "libxfixes3", "libxrandr2",
      "libgbm1", "libpango-1.0-0", "libcairo2", "libasound2",
      "libatspi2.0-0", "libdbus-1-3", "libx11-6", "libx11-xcb1",
      "libxcb1", "libxext6", "libxshmfence1", "fonts-liberation"
    ],
    "startCommand": "uv run gunicorn app:app --timeout 600 --workers 2 --graceful-timeout 600"
  }
}
