entrypoint = "main.py"
modules = ["python-3.11", "nodejs-20", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["gcc", "glibcLocales", "ocl-icd", "opencl-headers", "unzip"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["bash", "-c", "PORT=5000 python app.py"]
deploymentTarget = "autoscale"
build = ["bash", "-c", "npx vite build"]

[agent]
expertMode = true
integrations = ["python_log_in_with_replit:1.0.0", "stripe:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard API"

[[workflows.workflow]]
name = "Dashboard API"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 python app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
