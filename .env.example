# RevenueCat iOS API key (starts with appl_).
#
# IMPORTANT: this is a Vite build-time env var, baked into the JS bundle by
# `npm run build`. The iOS Capacitor app loads its WebView from
# https://app.sharppicks.ai (per capacitor.config.json server.url), so the
# bundle that matters is the one Railway builds, NOT the one built locally.
# This var MUST be set in Railway's environment so it lands in the
# production JS bundle. Setting it only in a local .env will not help
# the iOS app since the iOS app fetches JS over HTTPS at runtime.
#
# If you forget this on a fresh deploy, the iOS paywall renders the
# "Unable to load App Store products" error and the subscribe button
# does nothing, because RC SDK never gets configured.
VITE_REVENUECAT_IOS_KEY=

# RevenueCat webhook shared secret (generate with: openssl rand -hex 32)
REVENUECAT_WEBHOOK_SECRET=

# Native Sign in with Apple iOS bundle ID audience (usually matches capacitor.config.json appId)
# Example: com.sharppicksllc.signals
APPLE_IOS_CLIENT_ID=

# Cloudflare Web Analytics for /api/admin/metrics (Phase 2). Uses the
# rumPageloadEventsAdaptiveGroups dataset (free-tier compatible, multi-day
# ranges). Mirrors the auth model of the legacy /api/admin/cf-analytics
# endpoint. The new code falls back to CF_API_TOKEN / CF_ACCOUNT_ID /
# CF_WEB_ANALYTICS_SITE_TAG if these CLOUDFLARE_* are unset, so existing
# Railway env vars work without duplication. Set these only if you want
# to use a different token/account/site than the legacy endpoint.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_SITE_TAG=

# Google OAuth refresh token for GA4 + Search Console (Phase 2).
# Capture once via: python3 scripts/get_google_refresh_token.py
# Sign in as evan@sharppicks.ai when the browser opens.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
