# RevenueCat iOS API key (starts with appl_)
VITE_REVENUECAT_IOS_KEY=

# RevenueCat webhook shared secret (generate with: openssl rand -hex 32)
REVENUECAT_WEBHOOK_SECRET=

# Native Sign in with Apple iOS bundle ID audience (usually matches capacitor.config.json appId)
# Example: com.sharppicksllc.signals
APPLE_IOS_CLIENT_ID=

# Cloudflare Web Analytics for /api/admin/metrics (Phase 2). Uses the
# rumPageloadEventsAdaptiveGroups dataset (free-tier compatible, multi-day
# ranges). Mirrors the auth model of the legacy /api/admin/cf-analytics
# endpoint. The new code falls back to CF_API_TOKEN / CF_ACCOUNT_ID /
# CF_WEB_ANALYTICS_SITE_TAG if these CLOUDFLARE_* are unset, so existing
# Railway env vars work without duplication. Set these only if you want
# to use a different token/account/site than the legacy endpoint.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_SITE_TAG=
